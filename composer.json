{
    "name": "jsdevart/laravel-file-vault",
    "description": "Private file storage for Laravel with signed URLs and multi-context.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "file-storage",
        "private-files",
        "signed-url",
        "s3",
        "file-upload"
    ],
    "authors": [
        {
            "name": "JSDevArt",
            "email": "packages@jsdevart.com"
        }
    ],
    "homepage": "https://github.com/JSDevArt/laravel-file-vault",
    "support": {
        "issues": "https://github.com/JSDevArt/laravel-file-vault/issues",
        "source": "https://github.com/JSDevArt/laravel-file-vault"
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "pestphp/pest": "^3.8",
        "phpunit/phpunit": "11.5.50"
    },
    "autoload": {
        "psr-4": {
            "JSDevArt\\LaravelFileVault\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JSDevArt\\LaravelFileVault\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "format": "pint"
    },
    "extra": {
        "laravel": {
            "providers": [
                "JSDevArt\\LaravelFileVault\\FileVaultServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}